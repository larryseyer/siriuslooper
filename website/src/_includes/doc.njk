---
layout: base.njk
bodyClass: doc
---
<article class="doc">
  <div class="container doc-grid">
    <aside class="doc-aside" aria-label="Document navigation">
      <div class="doc-aside-inner">
        <p class="doc-kicker">Sirius Looper · Documentation</p>
        <h2 class="doc-title-aside">{{ title }}</h2>
        <nav class="doc-toc" aria-label="On this page">
          <p class="doc-toc-label">On this page</p>
          <ol id="doc-toc-list"><!-- populated by signup.js companion --></ol>
        </nav>
        <p class="doc-aside-meta">
          <a href="{{ site.github }}/blob/master/docs/{{ sourceFile | urlEncode }}" rel="noopener">View source on GitHub →</a>
        </p>
      </div>
    </aside>
    <div class="doc-body prose">
      <h1>{{ title }}</h1>
      {% if subtitle %}<p class="doc-subtitle">{{ subtitle }}</p>{% endif %}
      {{ content | safe }}
    </div>
  </div>
</article>
