---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- set pages = collections.all -%}
{%- for p in pages -%}
  {%- if p.url and not p.url.endsWith('.xml') and not p.url.endsWith('.txt') and p.url != '/404.html' %}
  <url>
    <loc>{{ p.url | absoluteUrl(site.url) }}</loc>
    <lastmod>{{ (p.date or page.date) | isoDate }}</lastmod>
  </url>
  {%- endif -%}
{%- endfor %}
</urlset>
